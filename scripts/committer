#!/usr/bin/env bash
# Safe commit helper — stages only listed files, enforces non-empty messages.
# Usage: committer [--force] "commit message" file1 [file2 ...]
# --force: remove stale git lock if commit fails due to index.lock

set -euo pipefail
set -f

usage() {
  printf 'Usage: %s [--force] "commit message" "file" ["file" ...]\n' "$(basename "$0")" >&2
  exit 2
}

[ "$#" -lt 2 ] && usage

force_delete_lock=false
if [ "${1:-}" = "--force" ]; then
  force_delete_lock=true
  shift
fi

[ "$#" -lt 2 ] && usage

commit_message=$1; shift

[[ "$commit_message" != *[![:space:]]* ]] && { printf 'Error: empty commit message\n' >&2; exit 1; }
[ -e "$commit_message" ] && { printf 'Error: first arg looks like a file path\n' >&2; exit 1; }
[ "$#" -eq 0 ] && usage

files=("$@")

for file in "${files[@]}"; do
  [ "$file" = "." ] && { printf 'Error: "." not allowed; list specific paths\n' >&2; exit 1; }
done

# Allow staging deletions (file gone from disk but tracked in HEAD)
for file in "${files[@]}"; do
  if [ ! -e "$file" ]; then
    if ! git ls-files --error-unmatch -- "$file" >/dev/null 2>&1; then
      if ! git cat-file -e "HEAD:$file" >/dev/null 2>&1; then
        printf 'Error: file not found: %s\n' "$file" >&2
        exit 1
      fi
    fi
  fi
done

# Auto-fix lint issues on staged Python files before committing
py_files=()
for file in "${files[@]}"; do
  [[ "$file" == *.py ]] && py_files+=("$file")
done
if [ "${#py_files[@]}" -gt 0 ]; then
  ruff check --fix --quiet "${py_files[@]}" 2>/dev/null || true
fi

git restore --staged :/ 2>/dev/null || true
git add -A -- "${files[@]}"

if git diff --staged --quiet; then
  printf 'Warning: no staged changes for: %s\n' "${files[*]}" >&2
  exit 1
fi

last_commit_error=''

run_git_commit() {
  local stderr_log
  stderr_log=$(mktemp)
  if git commit -m "$commit_message" -- "${files[@]}" 2> >(tee "$stderr_log" >&2); then
    rm -f "$stderr_log"
    last_commit_error=''
    return 0
  fi
  last_commit_error=$(cat "$stderr_log")
  rm -f "$stderr_log"
  return 1
}

committed=false
if run_git_commit; then
  committed=true
elif [ "$force_delete_lock" = true ]; then
  lock_path=$(
    printf '%s\n' "$last_commit_error" |
      awk -F"'" '/Unable to create .*\.git\/index\.lock/ { print $2; exit }'
  )
  if [ -n "$lock_path" ] && [ -e "$lock_path" ]; then
    rm -f "$lock_path"
    printf 'Removed stale git lock: %s\n' "$lock_path" >&2
    if run_git_commit; then
      committed=true
    fi
  fi
fi

if [ "$committed" = false ]; then
  exit 1
fi

printf 'Committed "%s" with %d files\n' "$commit_message" "${#files[@]}"
