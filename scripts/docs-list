#!/usr/bin/env python3
"""List all docs with summaries and read_when hints.

Usage: scripts/docs-list
"""

import os
import sys
from pathlib import Path

DOCS_DIR = Path(__file__).parent.parent / "docs"
EXCLUDED = {"archive", "research"}


def extract_frontmatter(path: Path) -> dict:
    text = path.read_text()
    if not text.startswith("---"):
        return {"error": "missing front matter"}
    end = text.index("\n---", 3) if "\n---" in text[3:] else -1
    if end == -1:
        return {"error": "unterminated front matter"}
    fm = text[3:end + 1].strip()

    summary = None
    read_when = []
    collecting = False

    for line in fm.split("\n"):
        stripped = line.strip()
        if stripped.startswith("summary:"):
            summary = stripped[len("summary:"):].strip().strip("'\"")
            collecting = False
        elif stripped.startswith("read_when:"):
            collecting = True
        elif collecting and stripped.startswith("- "):
            read_when.append(stripped[2:].strip())
        elif collecting and not stripped:
            pass
        else:
            collecting = False

    if not summary:
        return {"error": "no summary"}
    return {"summary": summary, "read_when": read_when}


def walk_docs(d: Path):
    for entry in sorted(d.iterdir()):
        if entry.name.startswith("."):
            continue
        if entry.is_dir():
            if entry.name not in EXCLUDED:
                yield from walk_docs(entry)
        elif entry.suffix == ".md":
            yield entry


def main():
    if not DOCS_DIR.exists():
        print(f"No docs/ directory at {DOCS_DIR}")
        sys.exit(1)

    print("Docs listing:\n")
    for path in walk_docs(DOCS_DIR):
        rel = path.relative_to(DOCS_DIR)
        meta = extract_frontmatter(path)
        if "error" in meta:
            print(f"  {rel} [{meta['error']}]")
        else:
            print(f"  {rel} - {meta['summary']}")
            for hint in meta.get("read_when", []):
                print(f"    → Read when: {hint}")
        print()

    print(
        "Reminder: Before coding, check if any doc's 'Read when' matches your task. "
        "Read that doc first."
    )


if __name__ == "__main__":
    main()
