# =============================================================================
# NHC Capital — Environment Variables
# Copy to .env and fill in real values. Never commit the .env file.
# =============================================================================

# ── Database (shared across sub-projects) ────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_USER=nhc_agent
DB_PASSWORD=
DB_NAME=nhl_betting

# ── Admin Dashboard ──────────────────────────────────────────────────────────
DASHBOARD_DB_USER=dashboard_readonly
DASHBOARD_DB_PASS=
DATABASE_HOST=localhost
DATABASE_PORT=5432
DASHBOARD_API_KEY=your_api_key_here
DASHBOARD_HOST=127.0.0.1
DASHBOARD_PORT=8000

# CORS origins (comma-separated). Add your Cloudflare domain here.
CORS_ORIGINS=http://localhost:8000,http://127.0.0.1:8000,http://localhost:3000,https://dashboard.nhc-capital.com

# Allowed OAuth emails (comma-separated)
ALLOWED_EMAILS=you@example.com

# ── NHL Betting ──────────────────────────────────────────────────────────────
ODDS_API_KEY=your_odds_api_key_here
DATABASE_URL=postgresql://nhc_agent@localhost:5432/nhl_betting

# ── Real Estate (Cook County) ───────────────────────────────────────────────
SODA_API_TOKEN=your_soda_token_here
SODA_API_KEY=your_soda_key_here

# ── Code Review (CI/CD) ─────────────────────────────────────────────────────
NVIDIA_API_KEY=your_nvidia_key_here
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1
OPENROUTER_API_KEY=your_openrouter_key_here

# ── Polymarket ───────────────────────────────────────────────────────────────
# PI_HOST=user@your-pi-ip  (for sync_from_pi.sh)
